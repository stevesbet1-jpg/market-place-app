# Supabase Configuration (already configured)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# =============================================================================
# FIREBASE CONFIGURATION — YOU MUST REPLACE ALL PLACEHOLDERS BELOW
# =============================================================================
#
# 1. Go to https://console.firebase.google.com
# 2. Select your project (or create one)
# 3. Click the gear icon (⚙️) next to "Project Overview" → "Project settings"
# 4. Under "Your apps", click "</>" (Web app)
# 5. Register app with nickname: marketplace-web
# 6. Copy the firebaseConfig values and PASTE THEM HERE, replacing YOUR_* values
#
# IMPORTANT: Do NOT leave YOUR_* placeholders. The app will fail with:
#   "FirebaseError: auth/api-key-not-valid"
#
# Also enable in Firebase Console:
#   Build → Authentication → Get started → Enable "Email/Password"
#   Build → Firestore Database → Create database
#
# =============================================================================

EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyYourRealApiKeyHere
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# =============================================================================
# RESEND EMAIL DELIVERY — CUSTOM PASSWORD RESET EMAILS
# =============================================================================
#
# 1. Sign up at https://resend.com
# 2. Create an API key → copy the key starting with "re_"
# 3. Verify a domain (e.g., yourdomain.com) or use onboarding@resend.dev for testing
# 4. Paste values below
#
# IMPORTANT: These are SERVER-ONLY keys. NEVER expose them in the Expo app.
# Only used by Node.js scripts in the scripts/ directory.
#
# =============================================================================

RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com
# For testing without a verified domain, use: EMAIL_FROM=onboarding@resend.dev

# =============================================================================
# BACKEND API SERVER (for Resend password reset from the app)
# =============================================================================
# The app calls this URL to send password reset emails via Resend.
# In development: run `npm run server` and use localhost below.
# In production: deploy the server/ directory and set this to your hosted URL.
# =============================================================================

EXPO_PUBLIC_RESET_API_URL=https://market-place-app-1.onrender.com

# Dedicated backend base URL for Stripe payment endpoints.
# This should point to the same server as EXPO_PUBLIC_RESET_API_URL unless payments are hosted separately.
EXPO_PUBLIC_PAYMENT_API_URL=https://market-place-app-1.onrender.com

# =============================================================================
# GOOGLE SIGN-IN (for "Continue with Google" on Login & Sign Up screens)
# =============================================================================
#
# STEP 1 — Enable Google in Firebase:
#   Firebase Console → Authentication → Sign-in method → Google → Enable
#   After enabling, Firebase auto-creates a "Web client (auto created by Google Service)".
#   Copy its Client ID — that is your Web Client ID.
#
# STEP 2 — Get your client IDs:
#   Go to: https://console.cloud.google.com/apis/credentials
#   Select your Firebase project.
#   Copy:
#     • Web Client ID  → EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID  (required)
#     • iOS Client ID  → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID  (optional, improves native flow)
#
# STEP 3 — Paste below and restart Expo with --clear flag:
#   npx expo start --clear
#
# NOTE: The button is hidden automatically if EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID is not set.
#
# =============================================================================

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id_here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here.apps.googleusercontent.com

# =============================================================================
# STRIPE — MEMBERSHIP PAYMENTS
# =============================================================================
#
# STEP 1 — Sign up at https://dashboard.stripe.com
# STEP 2 — Get your keys from: https://dashboard.stripe.com/apikeys
#   Publishable key (pk_test_...) — safe to expose in the app
#   Secret key (sk_test_...)      — SERVER ONLY, never put in the app
#
# STEP 3 — For webhooks (local testing):
#   Install Stripe CLI: https://stripe.com/docs/stripe-cli
#   Run: stripe listen --forward-to localhost:3001/api/stripe/webhook
#   Copy the webhook signing secret (whsec_...) to STRIPE_WEBHOOK_SECRET
#
# STEP 4 — For production:
#   Add a webhook endpoint in Stripe Dashboard → Developers → Webhooks
#   URL: https://your-render-domain.onrender.com/api/stripe/webhook
#   Events to send: payment_intent.succeeded
#
# =============================================================================

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
