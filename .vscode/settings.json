{
  "files.exclude": {
    "**/node_modules": true,
    "**/.expo": true,
    "**/dist": true,
    "**/build": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.expo/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.expo": true,
    "**/travel-marketplace-app/node_modules": true
  },
  "typescript.tsserver.watchOptions": {
    "excludeDirectories": ["node_modules", ".expo"]
  },
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "json.schemas": [
    {
      "fileMatch": ["**/node_modules/**/tsconfig.json", "**/node_modules/**/tsconfig*.json"],
      "schema": { "type": "object", "description": "Dependency tsconfig — not validated" }
    }
  ]
}
