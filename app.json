{
  "expo": {
    "name": "Matket-place",
    "slug": "Matket-place",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#071120",
    "userInterfaceStyle": "dark",
    "scheme": "marketplace",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#071120"
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.Matketplace",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Matketplace"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f407ae8-4e8a-4780-9087-f81351109e8e"
      },
      "supabaseUrl": "",
      "supabaseAnonKey": ""
    },
    "owner": "stevesbete1"
  }
}
